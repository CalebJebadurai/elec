# ── Database ──────────────────────────────────────────────
POSTGRES_DB=elec
POSTGRES_USER=elec
POSTGRES_PASSWORD=change_me_in_production
APP_DB_PASSWORD=change_me_app_password
DATABASE_URL=postgresql://elec_app:change_me_app_password@db:5432/elec

# ── API ───────────────────────────────────────────────────
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── JWT Auth ──────────────────────────────────────────────
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=72

# ── Firebase (for OTP via mobile) ─────────────────────────
# Get these from https://console.firebase.google.com
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=

# ── Google OAuth (for account linking) ────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Jupyter (dev only — do NOT expose in production) ──────
JUPYTER_TOKEN=change_me_random_token

# ── Frontend (Vite — must be prefixed with VITE_) ────────
VITE_API_URL=/api
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
